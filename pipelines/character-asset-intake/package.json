{
  "name": "@gameai/character-asset-intake",
  "version": "0.1.0",
  "private": true,
  "description": "Engine-neutral character asset loading, inspection, validation, and normalization.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm run build && tsc -p tsconfig.test.json && node --test dist-test/test/*.test.js",
    "fixtures:generate": "node scripts/generate-fixtures.mjs",
    "generate:simple-sprite": "node scripts/generate-simple-sprite-character.mjs",
    "generate:production-lite": "node scripts/generate-production-lite-character.mjs",
    "generate:production-lite-accessories": "node scripts/generate-production-lite-head-accessories.mjs",
    "generate:production-lite-garment": "node scripts/generate-production-lite-garment-layering.mjs",
    "verify:production-lite-accessories": "pnpm run build && node scripts/verify-production-lite-head-accessories.mjs",
    "verify:production-lite-garment": "pnpm run build && node scripts/verify-production-lite-garment-layering.mjs",
    "verify:production-lite": "pnpm run build && node scripts/verify-production-lite-reconstruction.mjs",
    "normalize:production-lite-cocos-metas": "node scripts/normalize-production-lite-cocos-metas.mjs",
    "normalize:production-lite-accessory-cocos-metas": "node scripts/normalize-production-lite-accessory-cocos-metas.mjs",
    "generate:production-lite-garment-cocos-metas": "node scripts/generate-production-lite-garment-cocos-metas.mjs",
    "reconstruct:red-cap": "node scripts/reconstruct-red-cap-remade.mjs",
    "audit:red-cap": "pnpm run build && node scripts/audit-red-cap-canonical-art.mjs",
    "audit:red-cap:report": "pnpm run build && node scripts/audit-red-cap-canonical-art.mjs --allow-blocked",
    "extract:red-cap-canonical": "node scripts/extract-canonical-parts.mjs",
    "generate:red-cap-overlaps": "node scripts/extract-canonical-parts.mjs && node scripts/generate-articulation-overlaps.mjs && node scripts/prepare-mapped-assets.mjs ../../examples/red-cap-target-remade/source-asset-map.json && pnpm --filter @gameai/rig-layout-generator fixtures:generate && node scripts/reconstruct-red-cap-remade.mjs && pnpm run audit:red-cap && node scripts/verify-articulation-stress.mjs && pnpm run sync:red-cap-cocos && node scripts/generate-cocos-articulation-scenes.mjs",
    "verify:red-cap-articulation": "pnpm run build && node scripts/verify-articulation-stress.mjs",
    "sync:red-cap-cocos": "node scripts/sync-cocos-fixture.mjs ../../examples/red-cap-target-remade ../../cocos/projects/character-rig-builder-mvp/assets/gameai/red-cap-target-remade"
  },
  "dependencies": {
    "@gameai/character-contracts": "workspace:*",
    "@gameai/rig-animation": "workspace:*",
    "sharp": "0.35.3"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:"
  }
}
