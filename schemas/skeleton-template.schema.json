{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gameai.dev/schemas/skeleton-template.schema.json",
  "title": "GameAI Skeleton Template",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "templateId", "referenceScale", "drawOrderPolicy", "additionalPartPolicy", "requiredParts", "parts", "animationTargets"],
  "properties": {
    "schemaVersion": { "type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$" },
    "templateId": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "referenceScale": { "type": "number", "exclusiveMinimum": 0 },
    "drawOrderPolicy": { "enum": ["unique", "shared"] },
    "additionalPartPolicy": { "enum": ["reject", "allow-with-overrides"] },
    "requiredParts": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" }
    },
    "parts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["partId", "parentId", "drawOrder"],
        "properties": {
          "partId": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "parentId": { "type": ["string", "null"] },
          "drawOrder": { "type": "integer" }
        }
      }
    },
    "sockets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["socketId", "parentPartId", "normalizedPosition", "rotationDegrees"],
        "properties": {
          "socketId": { "type": "string" },
          "parentPartId": { "type": "string" },
          "normalizedPosition": { "$ref": "#/definitions/normalizedVector" },
          "rotationDegrees": { "type": "number" }
        }
      }
    },
    "hitAreas": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["hitAreaId", "parentPartId", "normalizedShape"],
        "properties": {
          "hitAreaId": { "type": "string" },
          "parentPartId": { "type": "string" },
          "normalizedShape": {
            "oneOf": [
              { "$ref": "#/definitions/normalizedRect" },
              { "$ref": "#/definitions/normalizedCircle" }
            ]
          }
        }
      }
    },
    "animationTargets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["targetId", "partId"],
        "properties": {
          "targetId": { "type": "string" },
          "partId": { "type": "string" }
        }
      }
    }
  },
  "definitions": {
    "normalizedVector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    },
    "normalizedRect": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "x", "y", "width", "height"],
      "properties": {
        "type": { "const": "rect" },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "width": { "type": "number", "exclusiveMinimum": 0 },
        "height": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "normalizedCircle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "x", "y", "radius"],
      "properties": {
        "type": { "const": "circle" },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "radius": { "type": "number", "exclusiveMinimum": 0 }
      }
    }
  }
}
