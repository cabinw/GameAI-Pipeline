{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gameai-pipeline.dev/schemas/attachment-layout/v1.0.0",
  "title": "GameAI Attachment Layout",
  "description": "Engine-neutral slots and rigid Sprite attachments bound to a Rig Layout.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "attachmentLayoutId",
    "rig",
    "slots",
    "attachments"
  ],
  "properties": {
    "schemaVersion": {
      "$ref": "#/definitions/schemaVersion"
    },
    "attachmentLayoutId": {
      "$ref": "#/definitions/identifier"
    },
    "rig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layoutId", "schemaVersion"],
      "properties": {
        "layoutId": {
          "$ref": "#/definitions/identifier"
        },
        "schemaVersion": {
          "$ref": "#/definitions/schemaVersion"
        }
      }
    },
    "slots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/slot"
      }
    },
    "attachments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/attachment"
      }
    },
    "wearableSets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/wearableSet"
      }
    },
    "propStates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/propState"
      }
    },
    "seams": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/seam"
      }
    }
  },
  "definitions": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    },
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
    },
    "assetFilePath": {
      "type": "string",
      "minLength": 5,
      "maxLength": 512,
      "pattern": "^(?!/)(?![A-Za-z][A-Za-z0-9+.-]*:)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\)[^\\u0000]+\\.(?:png|jpg|jpeg|webp)$"
    },
    "vector2": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    },
    "scale2": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "number", "not": { "const": 0 } },
        "y": { "type": "number", "not": { "const": 0 } }
      }
    },
    "transform": {
      "type": "object",
      "additionalProperties": false,
      "required": ["position", "rotationDegrees", "scale"],
      "properties": {
        "position": { "$ref": "#/definitions/vector2" },
        "rotationDegrees": { "type": "number" },
        "scale": { "$ref": "#/definitions/scale2" }
      }
    },
    "normalizedAnchor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "number", "minimum": 0, "maximum": 1 },
        "y": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "slot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slotId",
        "parentPartId",
        "transform",
        "defaultEnabled"
      ],
      "properties": {
        "slotId": { "$ref": "#/definitions/identifier" },
        "parentPartId": { "$ref": "#/definitions/identifier" },
        "target": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "id"],
          "properties": {
            "kind": { "type": "string", "minLength": 1 },
            "id": { "$ref": "#/definitions/identifier" }
          }
        },
        "transform": { "$ref": "#/definitions/transform" },
        "defaultEnabled": { "type": "boolean" }
      }
    },
    "wearableSet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["wearableSetId", "defaultEnabled"],
      "properties": {
        "wearableSetId": { "$ref": "#/definitions/identifier" },
        "defaultEnabled": { "type": "boolean" }
      }
    },
    "propState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["propStateId", "defaultEnabled"],
      "properties": {
        "propStateId": { "$ref": "#/definitions/identifier" },
        "defaultEnabled": { "type": "boolean" }
      }
    },
    "coverageRegion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "width", "height"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "width": { "type": "number", "exclusiveMinimum": 0 },
        "height": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "seam": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "seamId",
        "firstItemId",
        "secondItemId",
        "firstRegion",
        "secondRegion",
        "minimumOverlap"
      ],
      "properties": {
        "seamId": { "$ref": "#/definitions/identifier" },
        "firstItemId": { "$ref": "#/definitions/identifier" },
        "secondItemId": { "$ref": "#/definitions/identifier" },
        "firstRegion": { "$ref": "#/definitions/coverageRegion" },
        "secondRegion": { "$ref": "#/definitions/coverageRegion" },
        "minimumOverlap": { "type": "number", "minimum": 0 }
      }
    },
    "attachment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "attachmentId",
        "slotId",
        "file",
        "transform",
        "anchor",
        "drawOrder"
      ],
      "properties": {
        "attachmentId": { "$ref": "#/definitions/identifier" },
        "slotId": { "$ref": "#/definitions/identifier" },
        "file": { "$ref": "#/definitions/assetFilePath" },
        "transform": { "$ref": "#/definitions/transform" },
        "anchor": { "$ref": "#/definitions/normalizedAnchor" },
        "drawOrder": { "type": "number" },
        "wearableSetId": { "$ref": "#/definitions/identifier" },
        "propStateId": { "$ref": "#/definitions/identifier" },
        "attachmentKind": { "type": "string", "minLength": 1 },
        "gripAnchor": { "$ref": "#/definitions/normalizedAnchor" },
        "handOverlayAttachmentId": { "$ref": "#/definitions/identifier" },
        "layerRole": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
